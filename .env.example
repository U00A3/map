# ── Dane węzłów (ustaw jedną z opcji) ─────────────────────────────────────
# A) Proxy do głównego dashboardu (zalecane na osobnym VPS - bez Postgresa na mapie)
#    Pełny origin, bez końcowego slasha, np. https://dashboard.example.com
NODES_API_UPSTREAM=

# B) Bezpośrednio ta sama baza co dashboard (wymaga sieciowej dostępności Postgresa)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Linki do głównej aplikacji (footer + przycisk w nagłówku) ─────────────
NEXT_PUBLIC_MAIN_APP_URL=https://your-dashboard.example.com

# ── Opcjonalnie: pasek „Network stats” w nagłówku (jak na dashboardzie) ───
NEXT_PUBLIC_CHAIN_ID=152
NEXT_PUBLIC_RPC_URL=https://your-mainnet-rpc.example.com

# GeoIP markerów (ip-api.com, HTTP): ~45 żądań / min z IP serwera (nie na godzinę)
# IP_API_GEO=0 - wyłączenie
# GEO_CACHE_TTL_MS=3600000 - legacy; sukces Geo używa GEO_REFRESH_SUCCESS_MS lub przypięcia
# Po zmianie IP za domeną: ponowny lookup ip-api po wygaśnięciu wpisu (wymaga restartu procesu po zmianie env)
GEO_REFRESH_SUCCESS_MS=86400000
# GEO_REFRESH_SUCCESS_MS=0 lub puste - przypnij udane współrzędne (bez okresowego odświeżania)
# GEO_CACHE_PATH=/ścieżka/ip-api-geo.json - opcjonalnie; domyślnie .cache/ip-api-geo.json w katalogu aplikacji
# IP_API_MIN_INTERVAL_MS=1500 - min. odstęp między zapytaniami w tle (~40/min)
#
# Trwały cache Geo w Postgres (ta sama baza co DATABASE_URL). Tabela: node_map_host_geo (auto-CREATE).
# GEO_CACHE_USE_DATABASE=true
